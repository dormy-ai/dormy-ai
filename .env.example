# Copy to .env and fill in values
DORMY_MODE=byok
DORMY_LOG_LEVEL=INFO

# Database (Supabase Postgres — use Session Pooler, NOT Direct,
# because Direct requires IPv6. Session Pooler works on any network.)
# Format: postgresql://postgres.<project-ref>:<URL-encoded-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Special characters in password must be URL-encoded: @ → %40  ! → %21  & → %26  # → %23
DORMY_DATABASE_URL=

# LLM providers (pick one or more)
DORMY_OPENROUTER_API_KEY=
DORMY_OPENAI_API_KEY=
DORMY_ANTHROPIC_API_KEY=
DORMY_MIROTHINKER_API_KEY=

# External services
DORMY_TAVILY_API_KEY=
DORMY_FIRECRAWL_API_KEY=
DORMY_STRIPE_SECRET_KEY=
DORMY_RESEND_API_KEY=
DORMY_TELEGRAM_BOT_TOKEN=

# Local Obsidian vault (for knowledge ingest)
DORMY_OBSIDIAN_VAULT_PATH=
