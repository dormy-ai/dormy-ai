# Copy to .env and fill in values
DORMY_MODE=byok
DORMY_LOG_LEVEL=INFO

# Database (Supabase Postgres)
DORMY_DATABASE_URL=

# LLM providers (pick one or more)
DORMY_OPENROUTER_API_KEY=
DORMY_OPENAI_API_KEY=
DORMY_ANTHROPIC_API_KEY=
DORMY_MIROTHINKER_API_KEY=

# External services
DORMY_TAVILY_API_KEY=
DORMY_FIRECRAWL_API_KEY=
DORMY_STRIPE_SECRET_KEY=
DORMY_RESEND_API_KEY=
DORMY_TELEGRAM_BOT_TOKEN=

# Local Obsidian vault (for knowledge ingest)
DORMY_OBSIDIAN_VAULT_PATH=
